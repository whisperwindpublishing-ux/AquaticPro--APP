{
  "name": "lesson-management",
  "version": "3.25.25",
  "description": "Build process for the Lesson Management WordPress plugin.",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "npx tailwindcss -i ./assets/css/input.css -o ./assets/css/tailwind.css --minify",
    "build:js": "npx esbuild src/index.js --bundle --outdir=assets/js --minify --loader:.js=jsx --jsx=automatic --external:@wordpress/*",
    "watch": "npx concurrently \"npm:watch:*\"",
    "watch:css": "npx tailwindcss -i ./assets/css/input.css -o ./assets/css/tailwind.css --watch",
    "watch:js": "npx esbuild src/index.js --bundle --outdir=assets/js --watch --loader:.js=jsx --jsx=automatic --external:@wordpress/*",
    "plugin-zip": "npm run build && npx bestzip lesson-management.zip admin/ assets/ includes/ lesson-management.php readme.txt"
  },
  "keywords": [
    "wordpress",
    "react",
    "tailwind"
  ],
  "author": "Swimming Ideas, LLC",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "bestzip": "^2.2.1",
    "concurrently": "^8.2.2",
    "esbuild": "^0.25.10",
    "react": "^18.3.1",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^18.3.1",
    "react-window": "^1.8.11",
    "react-window-infinite-loader": "^1.0.10",
    "tailwindcss": "^3.4.1"
  }
}
