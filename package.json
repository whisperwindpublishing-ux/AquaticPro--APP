{
  "name": "aquaticpro",
  "private": true,
  "version": "13.2.7",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:bento": "cd bento-grid && npm run build",
    "preview": "vite preview",
    "zip": "npm run build && npm run build:bento && bash -c 'rm -f aquaticpro.zip && mkdir -p /tmp/aquaticpro-zip/aquaticpro/bento-grid && cp -r build includes mentorship-platform.php index.html metadata.json /tmp/aquaticpro-zip/aquaticpro/ && cp -r bento-grid/build /tmp/aquaticpro-zip/aquaticpro/bento-grid/ && cd /tmp/aquaticpro-zip && zip -r aquaticpro.zip aquaticpro && mv aquaticpro.zip \"$OLDPWD/\" && rm -rf /tmp/aquaticpro-zip && echo \"Created aquaticpro.zip - upload this via WordPress Plugins > Add New > Upload Plugin\"'"
  },
  "dependencies": {
    "@blocknote/core": "^0.42.1",
    "@blocknote/mantine": "^0.42.1",
    "@blocknote/react": "^0.42.1",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "@tiptap/extension-placeholder": "^3.10.1",
    "@tiptap/react": "^3.10.1",
    "@tiptap/starter-kit": "^3.10.1",
    "@types/react-grid-layout": "^1.3.6",
    "framer-motion": "^12.26.2",
    "jspdf": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^2.2.2",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
