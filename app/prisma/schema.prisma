// AquaticPro — Full Prisma Schema (Phase 1)
// Generated from DATABASE_SCHEMA.md — all 65 custom tables + CPT-derived tables
// PostgreSQL via Supabase. No url/directUrl here — handled by prisma.config.ts (Prisma 7).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// CORE
// ============================================================

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  displayName String   @map("display_name")
  firstName   String?  @map("first_name")
  lastName    String?  @map("last_name")
  avatarUrl   String?  @map("avatar_url")
  phone       String?
  bio         String?
  tagline     String?
  mentorOptIn Boolean  @default(false) @map("mentor_opt_in")
  skills      String?  // JSON array of strings
  bioDetails  String?  @map("bio_details")
  experience  String?
  linkedinUrl String?  @map("linkedin_url")
  customLinks String?  @map("custom_links") // JSON array of {label, url}
  isMember    Boolean  @default(true)  @map("is_member")
  isArchived  Boolean  @default(false) @map("is_archived")
  supabaseUid String   @unique @map("supabase_uid")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model AppSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// ============================================================
// 1. DAILY LOGS MODULE
// ============================================================

model MpTimeSlot {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(100)
  label       String   @db.VarChar(255)
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  color       String?  @db.VarChar(7)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([sortOrder])
  @@map("mp_time_slots")
}

// Daily log — converted from WP CPT mp_daily_log to relational table
model DailyLog {
  id          Int      @id @default(autoincrement())
  authorId    Int      @map("author_id")
  locationId  Int?     @map("location_id")
  logDate     DateTime @map("log_date") @db.Date
  timeSlotIds String?  @map("time_slot_ids") // comma-separated IDs
  jobRoleId   Int?     @map("job_role_id")
  title       String?  @db.VarChar(255)
  tags        String?
  blocksJson  String?  @map("blocks_json") // BlockNote JSON content
  status      String   @default("publish") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([authorId, logDate])
  @@index([locationId])
  @@index([status])
  @@map("mp_daily_logs")
}

// Daily log comments — converted from WP native comments
model DailyLogComment {
  id        Int      @id @default(autoincrement())
  logId     Int      @map("log_id")
  userId    Int      @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([logId])
  @@index([userId])
  @@map("mp_daily_log_comments")
}

