// Mentorship Requests (mp_request CPT)
model MentorshipRequest {
  id         Int      @id @default(autoincrement())
  authorId   Int      @map("author_id")   // mentor
  receiverId Int      @map("receiver_id") // mentee
  status     String   @default("Pending") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([authorId])
  @@index([receiverId])
  @@index([status])
  @@map("mp_requests")
}

// Goals (mp_goal CPT)
model MentorshipGoal {
  id            Int      @id @default(autoincrement())
  mentorshipId  Int      @map("mentorship_id")
  authorId      Int      @map("author_id")
  title         String   @db.VarChar(255)
  content       String?
  status        String   @default("Not Started") @db.VarChar(30)
  isPortfolio   Boolean  @default(false) @map("is_portfolio")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([mentorshipId])
  @@index([authorId])
  @@map("mp_goals")
}

// Initiatives (mp_initiative CPT)
model MentorshipInitiative {
  id        Int      @id @default(autoincrement())
  goalId    Int      @map("goal_id")
  authorId  Int      @map("author_id")
  title     String   @db.VarChar(255)
  content   String?
  status    String   @default("Not Started") @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([goalId])
  @@map("mp_initiatives")
}

// Tasks (mp_task CPT)
model MentorshipTask {
  id           Int      @id @default(autoincrement())
  goalId       Int      @map("goal_id")
  initiativeId Int?     @map("initiative_id")
  authorId     Int      @map("author_id")
  title        String   @db.VarChar(255)
  content      String?
  isCompleted  Boolean  @default(false) @map("is_completed")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([goalId])
  @@index([initiativeId])
  @@map("mp_tasks")
}

// Meetings (mp_meeting CPT)
model MentorshipMeeting {
  id           Int      @id @default(autoincrement())
  goalId       Int      @map("goal_id")
  initiativeId Int?     @map("initiative_id")
  authorId     Int      @map("author_id")
  title        String   @db.VarChar(255)
  meetingDate  DateTime? @map("meeting_date")
  meetingLink  String?  @map("meeting_link") @db.VarChar(500)
  content      String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([goalId])
  @@index([initiativeId])
  @@map("mp_meetings")
}

// Updates (mp_update CPT)
model MentorshipUpdate {
  id           Int      @id @default(autoincrement())
  goalId       Int      @map("goal_id")
  initiativeId Int?     @map("initiative_id")
  authorId     Int      @map("author_id")
  title        String   @db.VarChar(255)
  content      String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([goalId])
  @@map("mp_updates")
}

// Lesson Management — Swimmers (lm-swimmer CPT)
model LmSwimmer {
  id                  Int      @id @default(autoincrement())
  title               String   @db.VarChar(255)  // swimmer name
  parentName          String?  @map("parent_name") @db.VarChar(255)
  parentEmail         String?  @map("parent_email") @db.VarChar(255)
  dateOfBirth         DateTime? @map("date_of_birth") @db.Date
  notes               String?
  currentLevel        Int?     @map("current_level")
  levelsMastered      String?  @map("levels_mastered")   // JSON array of level IDs
  skillsMastered      String?  @map("skills_mastered")   // JSON array of {skill_id, date}
  evaluationToken     String?  @map("evaluation_token") @db.VarChar(64)
  evaluationTokenExp  DateTime? @map("evaluation_token_expires")
  archived            Boolean  @default(false)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([archived])
  @@map("lm_swimmers")
}

// Lesson Management — Levels (lm-level CPT)
model LmLevel {
  id              Int      @id @default(autoincrement())
  title           String   @db.VarChar(255)
  sortOrder       Int      @default(0) @map("sort_order")
  relatedSkills   String?  @map("related_skills")  // JSON array of skill IDs
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("lm_levels")
}

// Lesson Management — Skills (lm-skill CPT)
model LmSkill {
  id              Int      @id @default(autoincrement())
  title           String   @db.VarChar(255)
  sortOrder       Int      @default(0) @map("sort_order")
  levelAssociated Int?     @map("level_associated")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("lm_skills")
}

// Lesson Management — Groups (lm-group CPT)
model LmGroup {
  id              Int      @id @default(autoincrement())
  title           String   @db.VarChar(255)
  level           Int?     // FK → LmLevel.id
  instructors     String?  // JSON array of user IDs
  swimmers        String?  // JSON array of LmSwimmer IDs
  swimmerGrouping String?  @map("swimmer_grouping")  // JSON object
  days            String?  // JSON array of day strings
  groupTime       String?  @map("group_time") @db.VarChar(50)
  datesOffered    String?  @map("dates_offered")  // JSON array of date strings
  notes           String?
  mediaId         Int?     @map("media_id")
  archived        Boolean  @default(false)
  year            Int?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([archived])
  @@index([year])
  @@map("lm_groups")
}

// ─── Media Library ───────────────────────────────────────────────────────────
// Central file/image store. All BlockNote uploads land here.
// canModerateAll on dailyLogs → see all files; otherwise own only.
model MediaFile {
  id          Int      @id @default(autoincrement())
  uploaderId  Int      @map("uploader_id")
  fileName    String   @map("file_name")    @db.VarChar(255)
  fileSize    Int      @map("file_size")
  mimeType    String   @map("mime_type")    @db.VarChar(100)
  bucket      String   @db.VarChar(50)
  storagePath String   @map("storage_path") @db.VarChar(500)
  publicUrl   String   @map("public_url")   @db.Text
  altText     String?  @map("alt_text")     @db.VarChar(500)
  logId       Int?     @map("log_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt           @map("updated_at")

  @@index([uploaderId])
  @@index([logId])
  @@index([createdAt])
  @@map("mp_media_files")
}

// Lesson Management — Evaluations (lm-evaluation CPT)
model LmEvaluation {
  id             Int      @id @default(autoincrement())
  swimmerId      Int      @map("swimmer_id")
  levelEvaluated Int?     @map("level_evaluated")
  emailed        Boolean  @default(false)
  createdBy      Int      @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([swimmerId])
  @@map("lm_evaluations")
}
