model AwesomeAwardsPeriod {
  id                      Int      @id @default(autoincrement())
  name                    String?  @db.VarChar(255)
  periodType              String   @map("period_type") @db.VarChar(10)
  startDate               DateTime @map("start_date") @db.Date
  endDate                 DateTime @map("end_date") @db.Date
  votingStart             DateTime? @map("voting_start") @db.Date
  votingEnd               DateTime? @map("voting_end") @db.Date
  nominationDeadline      DateTime? @map("nomination_deadline")
  status                  String   @default("draft") @db.VarChar(50)
  archived                Boolean  @default(false)
  maxWinners              Int      @default(1) @map("max_winners")
  allowPreVoting          Boolean  @default(false) @map("allow_pre_voting")
  createdBy               Int?     @map("created_by")
  tasklistId              Int?     @map("tasklist_id")
  taskdeckEnabled         Boolean  @default(false) @map("taskdeck_enabled")
  nominationReminderRoles String?  @map("nomination_reminder_roles")
  votingReminderRoles     String?  @map("voting_reminder_roles")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([startDate, endDate])
  @@index([archived])
  @@map("awesome_awards_periods")
}

